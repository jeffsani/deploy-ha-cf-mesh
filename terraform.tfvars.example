# Cloudflare credentials — set these in Terraform Cloud workspace variables
# or copy this file to temp.auto.tfvars for local development.
cloudflare_account_id = "your-cloudflare-account-id"
cloudflare_api_token  = "your-cloudflare-api-token"

# Cloudflare Zero Trust team name (the subdomain in <team>.cloudflareaccess.com)
team_name = "your-team-name"

# Existing WARP Access Application ID (see README for how to find this)
warp_app_id = "your-warp-app-id"

# Regions — one HA mesh connector per region (default: ["default"])
# regions = ["us-east", "eu-west"]

# MNM (Magic Network Monitoring) device registration is handled automatically
# by the install scripts — pass the router IP as the second argument.
# See scripts/install_debian.sh or scripts/install_rhel.sh for usage.

# Service token duration (default: 1 year)
# service_token_duration = "8760h"
